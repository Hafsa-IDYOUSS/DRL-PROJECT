import torch

from sklearn.metrics import accuracy_score


def compute_reward(model, dataloader, device):

    model.eval()

    predictions = []
    labels_list = []

    with torch.no_grad():

        for images, labels in dataloader:

            images = images.to(device)
            labels = labels.to(device)

            outputs = model(images)

            _, preds = torch.max(outputs, 1)

            predictions.extend(
                preds.cpu().numpy()
            )

            labels_list.extend(
                labels.cpu().numpy()
            )

    acc = accuracy_score(
        labels_list,
        predictions
    )

    return acc